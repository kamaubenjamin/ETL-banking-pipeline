# FlowSync / Supabase telemetry
# Copy to .env locally or provide these values through your production secret manager.
FLOWSYNC_SUPABASE_URL=https://your-project.supabase.co
FLOWSYNC_SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Optional overrides
FLOWSYNC_TELEMETRY_ENABLED=true
FLOWSYNC_TELEMETRY_RAISE_ON_ERROR=false
SUPABASE_SCHEMA=public
SUPABASE_TIMEOUT_SECONDS=15
SUPABASE_MAX_RETRIES=3
SUPABASE_RETRY_BACKOFF_SECONDS=0.5

# Optional table-name overrides if FlowSync uses custom names.
FLOWSYNC_PIPELINE_RUNS_TABLE=pipeline_runs
FLOWSYNC_INGESTION_LOGS_TABLE=ingestion_logs
FLOWSYNC_OPERATIONAL_ALERTS_TABLE=operational_alerts
